# SAP Connection Configuration
# 复制此文件为 .env 并填入您的SAP连接信息

# SAP用户名（必填）
SAP_USER=your_username

# SAP密码（必填）
SAP_PASSWORD=your_password

# SAP客户端（必填）
SAP_CLIENT=400

# SAP语言
SAP_LANG=ZH

# SAP主机地址（必填，不包含http://）
SAP_HOST=mysap.goodsap.cn

# SAP端口（必填）
SAP_PORT=50400

# SAP协议（http或https）
SAP_PROTOCOL=http

# 可选：直接指定完整URL（优先级最高）
# SAP_BASE_URL=http://mysap.goodsap.cn:50400
